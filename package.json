{
	"name": "farm-water-accounting",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "concurrently -k -n ui,api -c cyan,magenta \"npm run dev:ui\" \"npm run dev:api\"",
		"dev:ui": "vite dev",
		"dev:api": "bash -c 'set -e; python3 -m venv api/.venv; source api/.venv/bin/activate; pip install -q -r api/requirements.txt; exec uvicorn api.main:app --reload --port 8001 --host 127.0.0.1'",
		"setup:api": "python3 -m venv api/.venv && . api/.venv/bin/activate && pip install -r api/requirements.txt",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.8",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/vite": "^4.3.1",
		"@types/leaflet": "^1.9.16",
		"@types/leaflet-draw": "^1.0.13",
		"concurrently": "^9.2.4",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^5.0.0",
		"vite": "^6.0.0"
	},
	"dependencies": {
		"@ngageoint/geopackage": "^4.2.6",
		"@turf/area": "^7.3.5",
		"@turf/helpers": "^7.3.5",
		"@turf/union": "^7.3.5",
		"@types/sql.js": "^1.4.11",
		"jspdf": "^4.2.1",
		"jspdf-autotable": "^5.0.8",
		"jszip": "^3.10.1",
		"leaflet": "^1.9.4",
		"leaflet-draw": "^1.0.4",
		"shpjs": "^6.2.0",
		"sql.js": "^1.14.1"
	}
}
